# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root and nested workspaces — e.g. server/)
node_modules/
**/node_modules/

# server: never commit platform-specific ffmpeg/ffprobe binaries (install via npm on Linux/macOS)
server/node_modules/ffmpeg-static/ffmpeg
server/node_modules/ffmpeg-static/ffmpeg.exe
server/node_modules/ffprobe-static/bin/darwin/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/
/coverage

# next.js
.next/
/.next/
out/
/out/

# production / tooling output
dist/
build/
.turbo/
.vercel/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# typescript
*.tsbuildinfo
next-env.d.ts
